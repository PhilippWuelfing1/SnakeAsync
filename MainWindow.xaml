<Window x:Class="SnakeAsync.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SnakeAsync"
        mc:Ignorable="d"
        Title="MainWindow" Height="1600" Width="800" FocusManager.FocusedElement="{Binding ElementName=canv}">
    <Grid>
        <Canvas Name="canv"  PreviewKeyDown="canv_PreviewKeyDown" Height="1600" Width="800" Focusable="True">

        </Canvas>
    </Grid>
</Window>
