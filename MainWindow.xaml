<Window x:Class="SnakeAsync.MainWindow"
        x:Name="SnakeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SnakeAsync"
        mc:Ignorable="d"
        Title="MainWindow" Height="1400" Width="1400" FocusManager.FocusedElement="{Binding ElementName=canv}"
        StateChanged="Window_StateChanged"
        WindowState="Maximized"
        WindowStartupLocation="Manual"
        Left="0" 
        Top="0" 
        Loaded="Window_Loaded"        
        >

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="29*"/>
            <ColumnDefinition Width="1371*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Zeilenhöhe passt sich dem Inhalt an -->
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <!-- Zeile nimmt den restlichen verfügbaren Platz ein -->
        </Grid.RowDefinitions>

        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="20" FontWeight="Bold" Foreground="Black" Grid.Column="1" Margin="671,0,0,0">
            <TextBlock.Text>
                <MultiBinding StringFormat=" {0} , {1}">
                    <Binding ElementName="SnakeWindow" Path="SnakeHead_x" />
                    <Binding ElementName="SnakeWindow" Path="SnakeHead_y" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="20" FontWeight="Bold" Foreground="Black" Grid.Column="1" Margin="671,0,0,0">
            <TextBlock.Text>
                <MultiBinding StringFormat=" {0} , {1}">
                    <Binding ElementName="SnakeWindow" Path="SnakeHead_x" />
                    <Binding ElementName="SnakeWindow" Path="SnakeHead_y" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <TextBlock Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="20" FontWeight="Bold" Foreground="Black" Grid.Column="1" Margin="671,0,0,0">
            <TextBlock.Text>
                <MultiBinding StringFormat="Food: {0} , {1}">
                    <Binding ElementName="SnakeWindow" Path="Food_x" />
                    <Binding ElementName="SnakeWindow" Path="Food_y" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <Canvas Grid.Row="1"  Name="canv"  PreviewKeyDown="canv_PreviewKeyDown" Focusable="True" Grid.ColumnSpan="2" Margin="0,26,0,0" Grid.RowSpan="2">
            <Polyline 
                    Name="snake" 
                    Points="100,100 100,110 100,120 100,130 100,140 100,150 100,160 100,170 100,180 100,190 100,200"
                    Stroke="Green" 
                    StrokeThickness="10" 
                    StrokeLineJoin="Round" />
        </Canvas>

    </Grid>
</Window>
